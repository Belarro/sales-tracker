# NotionManager Production Validation - Environment Configuration Template
#
# Copy this file to .env.test and fill in your values:
#   cp .env.test.template .env.test
#
# Then load it:
#   source .env.test
#
# IMPORTANT: Never commit .env.test to git (it's in .gitignore)

# ============================================================================
# Notion Configuration (REQUIRED)
# ============================================================================

# Notion API Token
# Get from: https://www.notion.so/my-integrations
# Format: secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_TOKEN=

# Test Page IDs (get from page URLs)
# URL format: https://www.notion.so/Page-Title-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Copy the XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX part

# Simple test page (for basic sync tests)
NOTION_PAGE_SIMPLE=

# Rich content test page (optional - for advanced tests)
NOTION_PAGE_RICH=

# Image test page (optional - for file upload tests)
NOTION_PAGE_IMAGES=

# ============================================================================
# GitHub Configuration (OPTIONAL - for file upload tests)
# ============================================================================

# GitHub Personal Access Token
# Get from: https://github.com/settings/tokens
# Permissions needed: repo (Full control of private repositories)
# Format: ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_TOKEN=

# GitHub repository details
GITHUB_OWNER=
GITHUB_REPO=CollaborativeIntelligence

# ============================================================================
# Test Configuration
# ============================================================================

# Directory for test outputs
TEST_OUTPUT_DIR=./test-output

# ============================================================================
# Quick Start Checklist
# ============================================================================
#
# [ ] Created Notion integration at https://www.notion.so/my-integrations
# [ ] Created test page in Notion
# [ ] Shared test page with integration
# [ ] Copied NOTION_TOKEN above
# [ ] Copied NOTION_PAGE_SIMPLE above
# [ ] (Optional) Set GitHub credentials for file upload tests
# [ ] Saved this file as .env.test
# [ ] Ran: source .env.test
# [ ] Ready to run: node validation-test-1-notion-to-git.js
#
# ============================================================================
