# Notion API Configuration
# Get your token from: https://www.notion.so/my-integrations

# Required: Notion API token (starts with "secret_")
NOTION_API_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Default workspace/database IDs for CI integration
NOTION_WORKSPACE_ID=
NOTION_CI_AGENTS_DB_ID=
NOTION_CI_SESSIONS_DB_ID=
NOTION_CI_FILES_DB_ID=

# Optional: Rate limiting configuration
# Default: 600ms between requests (more conservative than Notion's 3 req/sec)
NOTION_RATE_LIMIT_MS=600

# Optional: Cost tracking and budget alerts
NOTION_DAILY_BUDGET_USD=10.00
NOTION_ALERT_THRESHOLD_USD=8.00

# Optional: Logging level
LOG_LEVEL=info  # debug | info | warn | error
